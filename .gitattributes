# Normalise les fins de ligne en LF dans le repo
# (les checkouts Windows recevront automatiquement CRLF si autocrlf est configuré)
* text=auto eol=lf

# Fichiers binaires (jamais convertis)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.webm binary
*.pdf binary
*.woff binary
*.woff2 binary
