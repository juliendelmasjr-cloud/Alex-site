# ═══════════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — Alexandre Delovane
# ═══════════════════════════════════════════════════════════════
# Copie ce fichier en `.env.local` pour le dev local.
# En production : configure ces variables sur Vercel
# (Project Settings → Environment Variables).
# Le fichier `.env.local` est ignoré par git.
# ═══════════════════════════════════════════════════════════════

# Clé secrète Stripe — UNIQUEMENT côté serveur
# Dashboard Stripe → Developers → API keys → Secret key
# En test : sk_test_...
# En live : sk_live_...
STRIPE_SECRET_KEY=sk_test_REMPLACER

# URL publique du site (sans slash final)
# Local :     http://localhost:5173
# Preview :   https://nom-projet-git-main.vercel.app
# Prod :      https://alexandre-delovane.com
SITE_URL=http://localhost:5173
